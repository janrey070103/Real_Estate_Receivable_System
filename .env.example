# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=real_estate_receivable_db
DB_USER=root
DB_PASS=

# Application Settings
APP_NAME="Real Estate Receivable System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/RERS/real_estate_receivable_system

# Session Configuration
SESSION_LIFETIME=120
SESSION_SECURE=false

# File Upload Settings
MAX_UPLOAD_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,jpeg,png

# Notification Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rers.com
SMTP_FROM_NAME="RERS Notifications"

# SMS Settings (e.g., Semaphore, Twilio)
SMS_API_KEY=
SMS_SENDER_NAME=RERS

# Timezone
TIMEZONE=Asia/Manila

# Security
PASSWORD_MIN_LENGTH=8
SESSION_NAME=RERS_SESSION
